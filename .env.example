# DT HUB Relay Server — Environment Variables
# Copy this to .env for local dev, set these in Railway dashboard for production

# Port (Railway sets this automatically)
PORT=3000

# Auth token — pick any strong random string, paste it into your DT HUB Profile settings
RELAY_AUTH_TOKEN=change-me-to-a-strong-secret

# Optional: restrict which origins can call this relay (comma-separated)
# Leave blank to allow all (fine for most setups)
ALLOWED_ORIGINS=

# FFmpeg binary path (leave blank — auto-detected on Railway/Render)
FFMPEG_PATH=

# Max concurrent streams (free Railway plan: keep at 5-10)
MAX_STREAMS=10

# Stream timeout in seconds — kill stuck streams after this long
STREAM_TIMEOUT_SECONDS=14400
